# HMS Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (Required)
# Supported providers: openai, groq, ollama, gemini, anthropic, lmstudio, vertexai, minimax, deepseek, zai, volcano
HMS_API_LLM_PROVIDER=openai
HMS_API_LLM_API_KEY=your-api-key-here
HMS_API_LLM_MODEL=gpt-4o-mini
HMS_API_LLM_BASE_URL=https://api.openai.com/v1

# Example: Anthropic Claude configuration
# HMS_API_LLM_PROVIDER=anthropic
# HMS_API_LLM_API_KEY=your-anthropic-api-key
# HMS_API_LLM_MODEL=claude-sonnet-4-20250514

# Example: Google Vertex AI configuration
# HMS_API_LLM_PROVIDER=vertexai
# HMS_API_LLM_MODEL=google/gemini-2.0-flash-001
# HMS_API_LLM_VERTEXAI_PROJECT_ID=your-gcp-project-id
# HMS_API_LLM_VERTEXAI_REGION=us-central1
# HMS_API_LLM_VERTEXAI_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json  # Optional, uses ADC if not set

# Example: MiniMax configuration (1M context window)
# HMS_API_LLM_PROVIDER=minimax
# HMS_API_LLM_API_KEY=your-minimax-api-key
# HMS_API_LLM_MODEL=MiniMax-M2.7

# Example: DeepSeek configuration (https://api.deepseek.com)
# HMS_API_LLM_PROVIDER=deepseek
# HMS_API_LLM_API_KEY=your-deepseek-api-key
# HMS_API_LLM_MODEL=deepseek-v4-flash  # or deepseek-v4-pro / deepseek-chat / deepseek-reasoner

# Example: z.ai configuration (Zhipu GLM series, https://z.ai)
# HMS_API_LLM_PROVIDER=zai
# HMS_API_LLM_API_KEY=your-zai-api-key
# HMS_API_LLM_MODEL=glm-4.5-flash  # or glm-4.5-air for the paid tier

# Example: LM Studio local configuration (Qwen 2.5 32B recommended)
# HMS_API_LLM_PROVIDER=lmstudio
# HMS_API_LLM_API_KEY=lmstudio
# HMS_API_LLM_BASE_URL=http://localhost:1234/v1
# HMS_API_LLM_MODEL=qwen2.5-32b-instruct

# API Configuration (Optional)
HMS_API_HOST=0.0.0.0
HMS_API_PORT=8888
HMS_API_LOG_LEVEL=info

# Base Path / Reverse Proxy Support (Optional)
# Set these when deploying behind a reverse proxy with path-based routing
# Example: To deploy at example.com/hms/, set both to "/hms"
# HMS_API_BASE_PATH=/hms
# NEXT_PUBLIC_BASE_PATH=/hms

# Database (Optional - uses embedded pg0 by default)
# HMS_API_DATABASE_URL=postgresql://user:pass@host:5432/db
# HMS_API_READ_DATABASE_URL=  # Optional read-replica URL. When set, recall queries (semantic, BM25, graph, temporal) flow through a separate pool against this URL, offloading the primary. Typically points to a read-only endpoint (CNPG's <cluster>-ro service or Aurora reader endpoint).
# HMS_API_MIGRATION_DATABASE_URL=  # Direct PostgreSQL URL for migrations (bypasses PgBouncer). Falls back to DATABASE_URL.
# HMS_API_DATABASE_SCHEMA=public  # PostgreSQL schema name (default: public)

# Vector Extension (Optional - uses pgvector by default)
# Options: "pgvector" (default), "vchord", "pgvectorscale" (DiskANN)
# HMS_API_VECTOR_EXTENSION=pgvector
# For Azure PostgreSQL with DiskANN:
# HMS_API_VECTOR_EXTENSION=pgvectorscale  # Auto-detects pg_diskann on Azure

# Embeddings Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# HMS_API_EMBEDDINGS_PROVIDER=local
# For local provider:
# HMS_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
# For TEI provider:
# HMS_API_EMBEDDINGS_TEI_URL=http://localhost:8080

# Reranker Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# HMS_API_RERANKER_PROVIDER=local
# For local provider:
# HMS_API_RERANKER_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# For TEI provider:
# HMS_API_RERANKER_TEI_URL=http://localhost:8081

# Observability & Tracing (Optional - disabled by default)
# Enable OpenTelemetry tracing for LLM calls (GenAI semantic conventions)
# HMS_API_OTEL_TRACES_ENABLED=true
#
# Local development with Grafana LGTM stack (recommended - see scripts/dev/grafana/README.md)
# HMS_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#
# Cloud backends (Grafana Cloud, Langfuse, DataDog, etc.)
# HMS_API_OTEL_EXPORTER_OTLP_ENDPOINT=https://your-backend-url
# HMS_API_OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer your-token"
#
# Custom service name and environment (optional, defaults: hms-api, development)
# HMS_API_OTEL_SERVICE_NAME=hms-production
# HMS_API_OTEL_DEPLOYMENT_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Control Plane (Optional)
# -----------------------------------------------------------------------------

# Dataplane API URL - where the CP proxies requests to
# HMS_CP_DATAPLANE_API_URL=http://localhost:8888

# Optional: Require a shared access key to view the Control Plane UI.
# When set, visitors see a login page and must enter the key before
# accessing the dashboard or any /api/* routes (except /api/health).
# HMS_CP_ACCESS_KEY=your-shared-secret-key

# -----------------------------------------------------------------------------
# Multi-API Benchmark Configuration (Optional)
# -----------------------------------------------------------------------------
# Configure multiple LLM APIs for parallel benchmark runs.
# Each API will run the same benchmark independently with its own results file.
# Usage: bash .aaaSCRIPT/run_benchmark.sh
#
# Format for each API: API_NAME:ENV_VAR_FOR_KEY:MODEL:BASE_URL
# The script will check if the API key env var is set before starting that benchmark.
#
# Example: KIMI_API_KEY (set in environment) for moonshot/kimi

# KIMI_API_KEY=your-kimi-api-key
# GLK_API_KEY=your-glk-api-key
# OPENAI_API_KEY=your-openai-api-key
