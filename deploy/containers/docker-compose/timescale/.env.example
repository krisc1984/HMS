# PostgreSQL Configuration
HMS_DB_USER=hms_user
HMS_DB_PASSWORD=change-me-to-secure-password
HMS_DB_NAME=hms_db

# HMS Version
HMS_VERSION=latest

# LLM Configuration
HMS_API_LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Alternative LLM providers (uncomment and configure as needed):
# HMS_API_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# HMS_API_LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key

# HMS_API_LLM_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key

# Vector and Text Search (already configured in docker-compose.yaml)
# HMS_API_VECTOR_EXTENSION=pgvectorscale
# HMS_API_TEXT_SEARCH_EXTENSION=pg_textsearch
