HMS_BASE_URL=http://127.0.0.1:8888
HMS_API_KEY=
HMS_BANK_ID=vendor-demo
HMS_TIMEOUT=300

# Gateway mode: expose this URL/key to vendors.
HMS_GATEWAY_HOST=0.0.0.0
HMS_GATEWAY_PORT=18081
HMS_GATEWAY_API_KEYS=hms_live_replace_me
HMS_GATEWAY_RATE_LIMIT_PER_MINUTE=60
HMS_GATEWAY_DAILY_QUOTA=1000
HMS_GATEWAY_AUDIT_LOG=/root/autodl-tmp/hanyh/hmsshadow/.aaaLOG/vendor_gateway_audit.jsonl
HMS_GATEWAY_SCOPE_BANK_IDS=true
HMS_GATEWAY_CHECK_INTERNAL_HEALTH=true
HMS_GATEWAY_INTERNAL_TIMEOUT=600

# Internal HMS API reached by the gateway. Do not share this key with vendors.
HMS_INTERNAL_BASE_URL=http://127.0.0.1:18080
HMS_INTERNAL_API_KEY=hms_internal_replace_me
